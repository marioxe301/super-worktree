{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "super-worktree Configuration",
  "description": "Configuration schema for super-worktree skill that manages git worktrees with env file copying and node_modules symlinking",
  "type": "object",
  "properties": {
    "sync": {
      "type": "object",
      "description": "Synchronization patterns for worktree creation",
      "properties": {
        "copyFiles": {
          "type": "array",
          "description": "Files to copy from source to worktree",
          "items": {
            "type": "string"
          },
          "default": [".env", ".env.*", ".envrc", ".local.*", "*.secret", "*.key", ".secrets.*", "credentials.json", "credentials.yml", "credentials.env", "auth.json", "auth.yml", "auth.env", ".dev.vars", ".prod.vars", ".staging.vars"]
        },
        "symlinkDirs": {
          "type": "array",
          "description": "Directories to symlink instead of copy",
          "items": {
            "type": "string"
          },
          "default": ["node_modules"]
        },
        "exclude": {
          "type": "array",
          "description": "Patterns to exclude from copying and symlinking",
          "items": {
            "type": "string"
          },
          "default": ["node_modules", ".git", "dist", "build", ".next", "out", "coverage", ".turbo", ".vercel", ".worktrees"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}