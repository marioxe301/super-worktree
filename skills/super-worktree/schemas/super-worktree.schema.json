{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "super-worktree Configuration",
  "description": "Configuration schema for super-worktree skill that manages git worktrees with env file copying and node_modules symlinking",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "description": "Config schema version. Current build expects 1.",
      "const": 1
    },
    "sync": {
      "type": "object",
      "description": "Synchronization patterns for worktree creation",
      "properties": {
        "copyFiles": {
          "type": "array",
          "description": "Files to copy from source to worktree",
          "items": {
            "type": "string"
          },
          "default": [".env", ".env.*", ".envrc", ".local.*", "*.secret", "*.key", ".secrets.*", "credentials.json", "credentials.yml", "credentials.env", "auth.json", "auth.yml", "auth.env", ".dev.vars", ".prod.vars", ".staging.vars"]
        },
        "symlinkDirs": {
          "type": "array",
          "description": "Directories to symlink instead of copy",
          "items": {
            "type": "string"
          },
          "default": ["node_modules"]
        },
        "exclude": {
          "type": "array",
          "description": "Patterns to exclude from copying and symlinking",
          "items": {
            "type": "string"
          },
          "default": ["node_modules", ".git", "dist", "build", ".next", "out", "coverage", ".turbo", ".vercel", ".worktrees"]
        },
        "copyDepth": {
          "type": "integer",
          "description": "Max directory depth (find -maxdepth) to scan for copyFiles/symlinkDirs. Use 1 for repo root only, 2+ for monorepo workspaces.",
          "minimum": 1,
          "default": 2
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "description": "Shell commands invoked at lifecycle phases. Receive env: BRANCH, BASE, WORKTREE_PATH.",
      "properties": {
        "preCreate":  { "type": "string", "description": "Run before git worktree add" },
        "postCreate": { "type": "string", "description": "Run after sync (e.g. 'pnpm install')" },
        "preDelete":  { "type": "string", "description": "Run before worktree removal" },
        "postDelete": { "type": "string", "description": "Run after worktree removal" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}